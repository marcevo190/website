---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Auto-pick hero image from src/assets/images/hero/ — first file found wins
const heroModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/hero/*.{jpg,jpeg,png,webp,JPG,JPEG}',
  { eager: true }
);
const heroImage = Object.values(heroModules)[0]?.default ?? null;


---

<Layout title="TrackMarc — Motorsport Photography">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    {heroImage ? (
      <Image
        src={heroImage}
        alt="Hero shot"
        class="hero-photo"
        widths={[800, 1440, 1920]}
        sizes="100vw"
        loading="eager"
      />
    ) : (
      <>
        <div class="hero-shapes"></div>
        <div class="hero-placeholder-label">
          <span>📷</span>
          Your hero shot<br />goes here
        </div>
      </>
    )}

    <div class="hero-content">
      <p class="hero-eyebrow">Motorsport Photography</p>
      <h1>Where Speed<br />Meets <em>Lens</em></h1>
      <p class="hero-desc">
        Capturing the raw intensity of motorsport — from Formula 2 to endurance classics.
        Available for media accreditation and editorial commissions.
      </p>
      <div class="hero-actions">
        <a href="/gallery" class="btn btn-primary">View Portfolio</a>
        <a href="/contact" class="btn btn-outline">Press Inquiry</a>
      </div>
    </div>

    <div class="hero-scroll">Scroll</div>
  </section>

  <!-- PRESS CTA BANNER -->
  <div class="press-cta-wrap">
    <div class="press-cta">
      <div>
        <p class="section-eyebrow">Media Accreditation</p>
        <h3 class="press-cta-title">Covering Your Event?</h3>
        <p class="press-cta-desc">
          I'm actively seeking media credentials at FIA, ACO, and national-level events.
          If you're a press officer or series coordinator, let's talk.
        </p>
      </div>
      <a href="/contact" class="btn btn-primary press-cta-btn">Get in Touch &rarr;</a>
    </div>
  </div>
</Layout>

<style>
  .press-cta-wrap {
    padding: 0 2rem;
    margin-bottom: 6rem;
  }
  .press-cta {
    max-width: var(--max-width);
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    padding: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .press-cta-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    margin: 0.5rem 0;
  }
  .press-cta-desc {
    color: var(--text-muted);
    font-weight: 300;
    margin-top: 0.5rem;
    max-width: 480px;
  }
  .press-cta-btn { flex-shrink: 0; }

  @media (max-width: 768px) {
    .press-cta-wrap { padding: 0 1.25rem; margin-bottom: 3rem; }
    .press-cta { padding: 1.75rem 1.25rem; flex-direction: column; align-items: flex-start; }
    .press-cta-btn { width: 100%; justify-content: center; }
  }
</style>
