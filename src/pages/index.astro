---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Gallery images for carousel rotation — shuffled across all categories
const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/watermarked/{formula,endurance,rally,gt,car-shows}/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);
const allImages = Object.values(galleryModules).map(m => m.default);
// Fisher-Yates shuffle
for (let i = allImages.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [allImages[i], allImages[j]] = [allImages[j], allImages[i]];
}
const slides = allImages.slice(0, 10);
---

<Layout title="TrackMarc — Motorsport Photography">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>

    <!-- Carousel -->
    {slides.length > 0 && (
      <div class="hero-carousel" id="hero-carousel">
        {slides.map((img, i) => (
          <div class:list={['carousel-slide', { active: i === 0 }]}>
            <Image
              src={img}
              alt="Motorsport photography by TrackMarc"
              class="carousel-img"
              widths={[800, 1440, 1920]}
              sizes="100vw"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
        <div class="carousel-overlay"></div>
      </div>
    )}

    <div class="hero-content">
      <p class="hero-eyebrow">Motorsport Photography</p>
      <h1>Where Speed<br />Meets <em>Lens</em></h1>
      <p class="hero-desc">
        Capturing the raw intensity of motorsport — from Formula 2 to endurance classics.
        Available for media accreditation and editorial commissions.
      </p>
      <div class="hero-actions">
        <a href="/gallery" class="btn btn-primary">View Portfolio</a>
        <a href="/contact" class="btn btn-outline">Press Inquiry</a>
      </div>
    </div>

    <div class="hero-scroll">Scroll</div>
  </section>

  <!-- PRESS CTA BANNER -->
  <div class="press-cta-wrap">
    <div class="press-cta">
      <div>
        <p class="section-eyebrow">Media Accreditation</p>
        <h3 class="press-cta-title">Covering Your Event?</h3>
        <p class="press-cta-desc">
          I'm actively seeking media credentials at FIA, ACO, and national-level events.
          If you're a press officer or series coordinator, let's talk.
        </p>
      </div>
      <a href="/contact" class="btn btn-primary press-cta-btn">Get in Touch &rarr;</a>
    </div>
  </div>
</Layout>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
  if (slides.length > 1) {
    let current = 0;
    setInterval(() => {
      slides[current].classList.remove('active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('active');
    }, 5000);
  }
</script>

<style>
  /* ── Carousel ── */
  .hero-carousel {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.5s ease;
  }
  .carousel-slide.active { opacity: 1; }
  .carousel-img {
    position: absolute;
    top: 0; right: 0;
    width: 62%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.6) 12%, black 28%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.6) 12%, black 28%);
  }
  /* Desktop overlay — subtle dark gradient over image area */
  .carousel-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(13,17,20,0.9) 100%);
    z-index: 1;
    pointer-events: none;
  }

  /* ── Mobile: full-width with dark overlay ── */
  @media (max-width: 768px) {
    .carousel-img {
      width: 100%;
      left: 0;
      mask-image: none;
      -webkit-mask-image: none;
      opacity: 0.55;
    }
    .carousel-overlay {
      background:
        linear-gradient(to bottom, rgba(13,17,20,0.25) 0%, rgba(13,17,20,0.5) 50%, rgba(13,17,20,0.95) 85%);
    }
  }

  /* ── Press CTA ── */
  .press-cta-wrap {
    padding: 0 2rem;
    margin-bottom: 6rem;
  }
  .press-cta {
    max-width: var(--max-width);
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    padding: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .press-cta-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    margin: 0.5rem 0;
  }
  .press-cta-desc {
    color: var(--text-muted);
    font-weight: 300;
    margin-top: 0.5rem;
    max-width: 480px;
  }
  .press-cta-btn { flex-shrink: 0; }

  @media (max-width: 768px) {
    .press-cta-wrap { padding: 0 1.25rem; margin-bottom: 3rem; }
    .press-cta { padding: 1.75rem 1.25rem; flex-direction: column; align-items: flex-start; }
    .press-cta-btn { width: 100%; justify-content: center; }
  }
</style>
