---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — TrackMarc Motorsport Photography"
  description="Page not found."
>
  <div style="padding-top: var(--nav-height); min-height: 80vh; display: flex; align-items: center;">
    <div class="section" style="text-align: center; width: 100%;">
      <p class="section-eyebrow">404</p>
      <h1 class="section-title">Page Not Found</h1>
      <p class="section-subtitle" style="margin: 0.75rem auto 2.5rem;">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/gallery" class="btn btn-outline">View Gallery</a>
      </div>
    </div>
  </div>
</Layout>
