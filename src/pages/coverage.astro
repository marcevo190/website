---
import Layout from '../layouts/Layout.astro';
import 'leaflet/dist/leaflet.css';

const locations = [
  {
    name: 'Autodromo Nazionale Monza',
    city: 'Monza, Italy',
    lat: 45.6156,
    lng: 9.2811,
    category: 'formula',
    events: ['FIA Formula 2 — Sep 2024'],
  },
  {
    name: 'Hungaroring',
    city: 'Budapest, Hungary',
    lat: 47.5789,
    lng: 19.2486,
    category: 'formula',
    events: ['FIA Formula 2 — 2024'],
  },
  {
    name: 'Circuit Zandvoort',
    city: 'Zandvoort, Netherlands',
    lat: 52.3888,
    lng: 4.5409,
    category: 'formula',
    events: ['Dutch GP weekend — 2024'],
  },
  {
    name: 'Circuit de la Sarthe',
    city: 'Le Mans, France',
    lat: 47.9497,
    lng: 0.2117,
    category: 'endurance',
    events: ['Le Mans 24 Hours — 2022', 'Le Mans 24 Hours — 2023', 'Le Mans 24 Hours — 2024'],
  },
  {
    name: 'Dublin',
    city: 'Dublin, Ireland',
    lat: 53.3498,
    lng: -6.2603,
    category: 'car-shows',
    events: ['Car Shows — 2023', 'Car Shows — 2024'],
  },
];

const stats = [
  { number: locations.length, label: 'Circuits & Venues' },
  { number: new Set(locations.map(l => l.city.split(', ')[1])).size, label: 'Countries' },
  { number: locations.reduce((n, l) => n + l.events.length, 0), label: 'Events Shot' },
];
---

<Layout
  title="Coverage — TrackMarc Motorsport Photography"
  description="World map of motorsport venues and events covered by TrackMarc."
>
  <div style="padding-top: var(--nav-height);">

    <!-- HEADER -->
    <div style="padding: 3rem 2rem 0; max-width: var(--max-width); margin: 0 auto;">
      <p class="section-eyebrow">Where I've Shot</p>
      <h1 class="section-title">Coverage Map</h1>
      <p class="section-subtitle">Click any marker to see events covered at that venue.</p>
    </div>

    <!-- STATS BAR -->
    <div style="display: flex; gap: 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); margin: 2rem 0;">
      {stats.map((s, i) => (
        <div style={`flex: 1; padding: 1.5rem 2rem; text-align: center; ${i > 0 ? 'border-left: 1px solid var(--border);' : ''}`}>
          <div style="font-family: var(--font-heading); font-size: 2rem; font-weight: 700; color: var(--accent);">{s.number}</div>
          <div style="font-family: var(--font-heading); font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-top: 0.25rem;">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- MAP -->
    <div id="map" style="width: 100%; height: 65vh; background: var(--surface);"></div>

    <!-- EVENT LIST -->
    <div style="padding: 4rem 2rem; max-width: var(--max-width); margin: 0 auto;">
      <div class="section-header">
        <p class="section-eyebrow">Venues</p>
        <h2 class="section-title">All Locations</h2>
      </div>
      <div class="events-grid">
        {locations.map(loc => (
          <div class="event-card">
            <div class="event-series" style="text-transform: capitalize;">{loc.category.replace('-', ' ')}</div>
            <div class="event-name">{loc.name}</div>
            <div class="event-detail">{loc.city}</div>
            <ul style="margin-top: 0.75rem; list-style: none; display: flex; flex-direction: column; gap: 0.3rem;">
              {loc.events.map(ev => (
                <li style="font-size: 0.78rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.5rem;">
                  <span style="display:block; width:0.35rem; height:0.35rem; background: var(--accent); flex-shrink:0;"></span>
                  {ev}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Accreditation goal -->
      <div style="background: var(--surface); border: 1px solid var(--border); border-left: 4px solid var(--accent); padding: 2.5rem; margin-top: 3rem;">
        <p style="font-family: var(--font-heading); font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem;">Goal for 2025</p>
        <h3 style="font-size: 1.5rem; margin-bottom: 0.75rem;">Targeting FIA Formula 1 Accreditation</h3>
        <p style="color: var(--text-muted); font-weight: 300; max-width: 600px;">
          Building toward a full FIA Formula 1 media pass application through demonstrated
          experience in FIA Formula 2, WEC, and WRC. Open to conversations with team media
          managers and FIA press officers.
        </p>
      </div>
    </div>
  </div>

  <script define:vars={{ locations }}>
    import('leaflet').then(({ default: L }) => {

      const map = L.map('map', { scrollWheelZoom: false });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; OpenStreetMap &copy; CARTO',
        subdomains: 'abcd',
        maxZoom: 19,
      }).addTo(map);

      const colour = '#00d2be';

      function makeIcon() {
        return L.divIcon({
          className: '',
          html: `<div style="width:14px;height:14px;background:${colour};border-radius:50%;border:2px solid rgba(255,255,255,0.3);box-shadow:0 0 0 4px ${colour}33,0 0 12px ${colour}66;"></div>`,
          iconSize: [14, 14],
          iconAnchor: [7, 7],
          popupAnchor: [0, -14],
        });
      }

      const bounds = [];
      locations.forEach((loc) => {
        const evList = loc.events
          .map(e => `<li style="margin:0.25rem 0;font-size:0.8rem;color:#8a9ba8;">&#x25AA; ${e}</li>`)
          .join('');
        const popup = `
          <div style="font-family:sans-serif;min-width:200px;">
            <div style="font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:${colour};margin-bottom:0.3rem;">${loc.category.replace('-', ' ')}</div>
            <div style="font-size:1rem;font-weight:700;color:#f0f0f0;text-transform:uppercase;letter-spacing:0.05em;">${loc.name}</div>
            <div style="font-size:0.75rem;color:#8a9ba8;margin-bottom:0.6rem;">${loc.city}</div>
            <ul style="list-style:none;padding:0;margin:0;border-top:1px solid #243038;padding-top:0.5rem;">${evList}</ul>
          </div>`;
        L.marker([loc.lat, loc.lng], { icon: makeIcon() })
          .addTo(map)
          .bindPopup(popup, { className: 'tm-popup', maxWidth: 280 });
        bounds.push([loc.lat, loc.lng]);
      });

      map.fitBounds(bounds, { padding: [60, 60] });
    });
  </script>

  <style is:global>
    .tm-popup .leaflet-popup-content-wrapper {
      background: #141a1e;
      border: 1px solid #243038;
      border-radius: 0;
      box-shadow: 0 4px 24px rgba(0,0,0,0.6);
      color: #f0f0f0;
    }
    .tm-popup .leaflet-popup-tip { background: #141a1e; }
    .tm-popup .leaflet-popup-close-button { color: #8a9ba8 !important; }
    .leaflet-control-zoom a { background: #141a1e !important; border-color: #243038 !important; color: #f0f0f0 !important; }
    .leaflet-control-zoom a:hover { background: #243038 !important; }
    .leaflet-control-attribution { background: rgba(13,17,20,0.8) !important; color: #4a5a65 !important; font-size: 0.65rem; }
    .leaflet-control-attribution a { color: #4a5a65 !important; }
  </style>
</Layout>
