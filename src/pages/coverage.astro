---
import Layout from '../layouts/Layout.astro';
import 'leaflet/dist/leaflet.css';

const locations = [
  {
    name: 'Autodromo Nazionale Monza',
    city: 'Monza, Italy',
    lat: 45.6156,
    lng: 9.2811,
    events: ['Formula 1', 'Formula 2'],
  },
  {
    name: 'Hungaroring',
    city: 'Budapest, Hungary',
    lat: 47.5789,
    lng: 19.2486,
    events: ['Formula 1', 'Formula 2'],
  },
  {
    name: 'Circuit Zandvoort',
    city: 'Zandvoort, Netherlands',
    lat: 52.3888,
    lng: 4.5409,
    events: ['Formula 1', 'Formula 2'],
  },
  {
    name: 'Circuit de la Sarthe',
    city: 'Le Mans, France',
    lat: 47.9497,
    lng: 0.2117,
    events: ['Le Mans 24 Hours'],
  },
  {
    name: 'Herbert Park',
    city: 'Dublin, Ireland',
    lat: 53.3264,
    lng: -6.2343,
    events: ['Herbert Park Car Show'],
  },
];
---

<Layout
  title="Upcoming Events — TrackMarc Motorsport Photography"
  description="Live motorsport calendar — F1, WEC, WRC, GT and Irish events automatically updated."
>
  <div style="padding-top: var(--nav-height);">

    <!-- WHERE I'VE SHOT MAP -->
    <div class="section" style="padding-bottom: 0;">
      <div class="section-header">
        <p class="section-eyebrow">Where I've Shot</p>
        <h2 class="section-title">Venues</h2>
        <p class="section-subtitle">Click a marker to see what was shot there.</p>
      </div>
    </div>
    <div id="map" style="width:100%; height:55vh; background:var(--surface);"></div>

    <!-- VENUE LIST -->
    <div class="section" style="padding-top: 2rem; padding-bottom: 3rem;">
      <div class="events-grid">
        {locations.map(loc => (
          <div class="event-card">
            <div class="event-name">{loc.name}</div>
            <div class="event-detail">{loc.city}</div>
            <ul style="margin-top:0.75rem;list-style:none;display:flex;flex-direction:column;gap:0.3rem;">
              {loc.events.map(ev => (
                <li style="font-size:0.78rem;color:var(--text-muted);display:flex;align-items:center;gap:0.5rem;">
                  <span style="display:block;width:0.35rem;height:0.35rem;background:var(--accent);flex-shrink:0;"></span>
                  {ev}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div style="border-top: 1px solid var(--border);"></div>

    <!-- UPCOMING EVENTS -->
    <div class="section">

      <div class="section-header">
        <p class="section-eyebrow">On The Radar</p>
        <h1 class="section-title">Upcoming Events</h1>
        <p class="section-subtitle">
          Live motorsport calendar — F1 race schedule and latest news from WEC, WRC, GT and Irish motorsport, automatically updated.
        </p>
      </div>

      <!-- F1 CALENDAR -->
      <div class="feed-section" id="f1-section">
        <h2 class="series-heading">
          <span class="series-dot"></span>
          Formula 1
          <span class="series-badge" id="f1-badge"></span>
        </h2>
        <div class="events-grid" id="f1-races">
          <div class="event-card loading-card"><div class="event-series">Loading F1 calendar…</div></div>
        </div>
      </div>

      <!-- WEC -->
      <div class="feed-section">
        <h2 class="series-heading">
          <span class="series-dot"></span>FIA World Endurance Championship
        </h2>
        <div class="news-grid" id="wec-news">
          <div class="news-card loading-card"><div class="news-title">Loading WEC news…</div></div>
        </div>
      </div>

      <!-- WRC -->
      <div class="feed-section">
        <h2 class="series-heading">
          <span class="series-dot"></span>FIA World Rally Championship
        </h2>
        <div class="news-grid" id="wrc-news">
          <div class="news-card loading-card"><div class="news-title">Loading WRC news…</div></div>
        </div>
      </div>

      <!-- GT WORLD CHALLENGE -->
      <div class="feed-section">
        <h2 class="series-heading">
          <span class="series-dot"></span>GT World Challenge Europe
        </h2>
        <div class="news-grid" id="gt-news">
          <div class="news-card loading-card"><div class="news-title">Loading GT news…</div></div>
        </div>
      </div>

      <!-- IRISH MOTORSPORT -->
      <div class="feed-section">
        <h2 class="series-heading">
          <span class="series-dot"></span>Irish Motorsport
        </h2>
        <div class="news-grid" id="irish-news">
          <div class="news-card loading-card"><div class="news-title">Loading Irish motorsport news…</div></div>
        </div>
      </div>

      <!-- CTA -->
      <div style="background:var(--surface);border:1px solid var(--border);border-left:4px solid var(--accent);padding:2.5rem;margin-top:3rem;">
        <p style="font-family:var(--font-heading);font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent);margin-bottom:0.75rem;">Accreditation</p>
        <h3 style="font-size:1.5rem;margin-bottom:0.75rem;">Seeking Media Access</h3>
        <p style="color:var(--text-muted);font-weight:300;max-width:600px;">
          If you're a press officer or series coordinator and you'd like to discuss media credentials, get in touch.
        </p>
        <a href="/contact" class="btn btn-primary" style="margin-top:1.5rem;display:inline-flex;">Contact Me &rarr;</a>
      </div>

    </div>
    </div><!-- close upcoming section -->
  </div>

  <!-- MAP SCRIPT -->
  <script define:vars={{ locations }}>
    import('leaflet').then(({ default: L }) => {
      const map = L.map('map', { scrollWheelZoom: false });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; OpenStreetMap &copy; CARTO',
        subdomains: 'abcd',
        maxZoom: 19,
      }).addTo(map);

      const colour = '#00d2be';
      const icon = L.divIcon({
        className: '',
        html: `<div style="width:14px;height:14px;background:${colour};border-radius:50%;border:2px solid rgba(255,255,255,0.25);box-shadow:0 0 0 4px ${colour}33,0 0 12px ${colour}66;"></div>`,
        iconSize: [14, 14], iconAnchor: [7, 7], popupAnchor: [0, -14],
      });

      const bounds = [];
      locations.forEach(loc => {
        const evList = loc.events.map(e => `<li style="margin:0.2rem 0;font-size:0.8rem;color:#8a9ba8;">&#x25AA; ${e}</li>`).join('');
        const popup = `
          <div style="font-family:sans-serif;min-width:180px;">
            <div style="font-size:1rem;font-weight:700;color:#f0f0f0;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.3rem;">${loc.name}</div>
            <div style="font-size:0.75rem;color:#8a9ba8;margin-bottom:0.6rem;">${loc.city}</div>
            <ul style="list-style:none;padding:0;margin:0;border-top:1px solid #243038;padding-top:0.5rem;">${evList}</ul>
          </div>`;
        L.marker([loc.lat, loc.lng], { icon }).addTo(map).bindPopup(popup, { className: 'tm-popup', maxWidth: 260 });
        bounds.push([loc.lat, loc.lng]);
      });
      map.fitBounds(bounds, { padding: [60, 60] });
    });
  </script>

  <!-- RSS + F1 SCRIPT -->
  <script>
    // ── helpers ──────────────────────────────────────────────────────────────

    function fmtDate(str: string) {
      const d = new Date(str);
      return isNaN(d.getTime()) ? str : d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
    }

    // Fetch RSS via allorigins CORS proxy, parse to items
    async function fetchRSS(url: string): Promise<{ title: string; link: string; pubDate: string; description: string }[]> {
      const proxy = `https://api.allorigins.win/get?url=${encodeURIComponent(url)}`;
      const res = await fetch(proxy);
      const json = await res.json();
      const parser = new DOMParser();
      const doc = parser.parseFromString(json.contents, 'text/xml');
      return Array.from(doc.querySelectorAll('item')).map(item => ({
        title: item.querySelector('title')?.textContent?.trim() ?? '',
        link: item.querySelector('link')?.textContent?.trim() ?? '#',
        pubDate: item.querySelector('pubDate')?.textContent?.trim() ?? '',
        description: item.querySelector('description')?.textContent?.replace(/<[^>]+>/g, '').slice(0, 120).trim() ?? '',
      }));
    }

    function renderNewsCards(containerId: string, items: { title: string; link: string; pubDate: string; description: string }[], count = 6) {
      const el = document.getElementById(containerId);
      if (!el) return;
      if (!items.length) {
        el.innerHTML = `<div class="news-card"><div class="news-title" style="opacity:0.4;">No recent news found</div></div>`;
        return;
      }
      el.innerHTML = items.slice(0, count).map(item => `
        <a href="${item.link}" target="_blank" rel="noopener" class="news-card">
          <div class="news-meta">${fmtDate(item.pubDate)}</div>
          <div class="news-title">${item.title}</div>
          ${item.description ? `<div class="news-desc">${item.description}…</div>` : ''}
        </a>`).join('');
    }

    function renderError(containerId: string, label: string) {
      const el = document.getElementById(containerId);
      if (el) el.innerHTML = `<div class="news-card"><div class="news-title" style="opacity:0.4;">Couldn't load ${label} feed — try refreshing.</div></div>`;
    }

    // ── F1 Race Calendar (Jolpica API) ────────────────────────────────────────
    (async () => {
      const year = new Date().getFullYear();
      const badge = document.getElementById('f1-badge');
      const container = document.getElementById('f1-races');
      if (badge) badge.textContent = `${year}`;
      try {
        const res = await fetch(`https://api.jolpi.ca/ergast/f1/${year}/races/?format=json&limit=30`);
        const data = await res.json();
        const races = (data?.MRData?.RaceTable?.Races ?? []) as any[];
        const now = new Date();
        const upcoming = races.filter(r => new Date(`${r.date}T${r.time ?? '12:00:00Z'}`) >= now);

        if (!container) return;
        if (!upcoming.length) {
          container.innerHTML = `<div class="event-card"><div class="event-series">Season complete — check back next year.</div></div>`;
          return;
        }
        container.innerHTML = upcoming.map(r => `
          <div class="event-card">
            <div class="event-series">Round ${r.round}</div>
            <div class="event-name">${r.raceName}</div>
            <div class="event-detail">${r.Circuit.circuitName}</div>
            <div class="event-detail" style="margin-top:0.2rem;">${r.Circuit.Location.locality}, ${r.Circuit.Location.country}</div>
            <div class="event-date">${fmtDate(r.date)}</div>
          </div>`).join('');
      } catch {
        renderError('f1-races', 'F1');
      }
    })();

    // ── RSS Feeds ─────────────────────────────────────────────────────────────
    const feeds = [
      { id: 'wec-news',   url: 'https://www.motorsport.com/rss/wec/news/',                   label: 'WEC' },
      { id: 'wrc-news',   url: 'https://www.motorsport.com/rss/wrc/news/',                   label: 'WRC' },
      { id: 'gt-news',    url: 'https://www.motorsport.com/rss/gt-world-challenge-europe/news/', label: 'GT' },
      { id: 'irish-news', url: 'https://www.motorsportireland.com/feed/',                    label: 'Irish motorsport' },
    ];

    feeds.forEach(({ id, url, label }) => {
      fetchRSS(url)
        .then(items => renderNewsCards(id, items))
        .catch(() => renderError(id, label));
    });
  </script>

  <style>
    .feed-section { margin-bottom: 4rem; }
    .series-heading {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.9rem;
      letter-spacing: 0.12em;
      color: var(--text-muted);
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border);
    }
    .series-dot {
      display: block;
      width: 0.45rem; height: 0.45rem;
      background: var(--accent);
      border-radius: 50%;
      flex-shrink: 0;
    }
    .series-badge {
      font-size: 0.65rem;
      color: var(--text-dim);
      letter-spacing: 0.1em;
    }
    .event-date {
      margin-top: 0.75rem;
      font-family: var(--font-heading);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
    }
    /* News grid — wider cards, horizontal scroll on mobile */
    .news-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }
    .news-card {
      background: var(--bg);
      padding: 1.25rem 1.5rem;
      display: block;
      text-decoration: none;
      color: inherit;
      transition: background 0.2s;
    }
    a.news-card:hover { background: var(--surface); }
    .news-meta {
      font-family: var(--font-heading);
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }
    .news-title {
      font-family: var(--font-heading);
      font-size: 0.9rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      line-height: 1.3;
      color: var(--text);
    }
    .news-desc {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
      line-height: 1.5;
    }
    .loading-card { opacity: 0.4; }
  </style>
</Layout>
