---
import Layout from '../layouts/Layout.astro';

const series = [
  {
    id: 'wec',
    label: 'FIA World Endurance Championship',
    calendarUrl: 'https://www.fiawec.com/en/season/',
    siteLabel: 'fiawec.com',
  },
  {
    id: 'wrc',
    label: 'FIA World Rally Championship',
    calendarUrl: 'https://www.wrc.com/en/calendar/',
    siteLabel: 'wrc.com',
  },
  {
    id: 'gt',
    label: 'GT World Challenge Europe',
    calendarUrl: 'https://www.gt-world-challenge-europe.com/calendar/',
    siteLabel: 'gt-world-challenge-europe.com',
  },
  {
    id: 'irish',
    label: 'Irish Motorsport',
    calendarUrl: 'https://motorsportireland.ie/events/',
    siteLabel: 'motorsportireland.ie',
  },
];
---

<Layout
  title="Motorsport — TrackMarc Motorsport Photography"
  description="Live F1 race calendar plus official WEC, WRC, GT and Irish motorsport calendars."
>
  <div style="padding-top: var(--nav-height);">
    <div class="section">

      <div class="section-header">
        <p class="section-eyebrow">The Sport</p>
        <h1 class="section-title">Motorsport</h1>
        <p class="section-subtitle">
          Live race calendars — F1 via live API, WEC, WRC, GT and Irish motorsport direct from the official sites.
        </p>
      </div>

      <!-- F1 CALENDAR -->
      <div class="feed-section" id="f1-section">
        <h2 class="series-heading">
          <span class="series-dot"></span>
          Formula 1
          <span class="series-badge" id="f1-badge"></span>
        </h2>
        <div class="events-grid" id="f1-races">
          <div class="event-card loading-card"><div class="event-series">Loading F1 calendar…</div></div>
        </div>
      </div>

      <!-- EMBEDDED SERIES CALENDARS -->
      {series.map(s => (
        <div class="feed-section">
          <h2 class="series-heading">
            <span class="series-dot"></span>{s.label}
          </h2>
          <div class="embed-wrap">
            <iframe
              src={s.calendarUrl}
              title={`${s.label} calendar`}
              class="embed-frame"
              loading="lazy"
              sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
            ></iframe>
            <a href={s.calendarUrl} target="_blank" rel="noopener" class="embed-link">
              Open {s.siteLabel} &rarr;
            </a>
          </div>
        </div>
      ))}

      <!-- CTA -->
      <div style="background:var(--surface);border:1px solid var(--border);border-left:4px solid var(--accent);padding:2.5rem;margin-top:3rem;">
        <p style="font-family:var(--font-heading);font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent);margin-bottom:0.75rem;">Accreditation</p>
        <h3 style="font-size:1.5rem;margin-bottom:0.75rem;">Seeking Media Access</h3>
        <p style="color:var(--text-muted);font-weight:300;max-width:600px;">
          If you're a press officer or series coordinator and you'd like to discuss media credentials, get in touch.
        </p>
        <a href="/contact" class="btn btn-primary" style="margin-top:1.5rem;display:inline-flex;">Contact Me &rarr;</a>
      </div>

    </div>
  </div>

  <script>
    function fmtDate(str: string) {
      const d = new Date(str);
      return isNaN(d.getTime()) ? str : d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
    }

    (async () => {
      const year = new Date().getFullYear();
      const badge = document.getElementById('f1-badge');
      const container = document.getElementById('f1-races');
      if (badge) badge.textContent = `${year}`;
      try {
        const res = await fetch(`https://api.jolpi.ca/ergast/f1/${year}/races/?format=json&limit=30`);
        const data = await res.json();
        const races = (data?.MRData?.RaceTable?.Races ?? []) as any[];
        const now = new Date();
        const upcoming = races.filter(r => new Date(`${r.date}T${r.time ?? '12:00:00Z'}`) >= now);
        if (!container) return;
        if (!upcoming.length) {
          container.innerHTML = `<div class="event-card"><div class="event-series">Season complete — check back next year.</div></div>`;
          return;
        }
        container.innerHTML = upcoming.map(r => `
          <div class="event-card">
            <div class="event-series">Round ${r.round}</div>
            <div class="event-name">${r.raceName}</div>
            <div class="event-detail">${r.Circuit.circuitName}</div>
            <div class="event-detail" style="margin-top:0.2rem;">${r.Circuit.Location.locality}, ${r.Circuit.Location.country}</div>
            <div class="event-date">${fmtDate(r.date)}</div>
          </div>`).join('');
      } catch {
        const el = document.getElementById('f1-races');
        if (el) el.innerHTML = `<div class="event-card"><div class="event-series" style="opacity:0.4;">Couldn't load F1 calendar.</div></div>`;
      }
    })();
  </script>

  <style>
    .feed-section { margin-bottom: 4rem; }
    .series-heading {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.9rem;
      letter-spacing: 0.12em;
      color: var(--text-muted);
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border);
    }
    .series-dot {
      display: block;
      width: 0.45rem; height: 0.45rem;
      background: var(--accent);
      border-radius: 50%;
      flex-shrink: 0;
    }
    .series-badge {
      font-size: 0.65rem;
      color: var(--text-dim);
      letter-spacing: 0.1em;
    }
    .event-date {
      margin-top: 0.75rem;
      font-family: var(--font-heading);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .loading-card { opacity: 0.4; }
    .embed-wrap {
      border: 1px solid var(--border);
      overflow: hidden;
    }
    .embed-frame {
      width: 100%;
      height: 520px;
      border: none;
      display: block;
      background: #fff;
      color-scheme: light;
    }
    .embed-link {
      display: block;
      padding: 0.6rem 1rem;
      font-family: var(--font-heading);
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      background: var(--surface);
      border-top: 1px solid var(--border);
      text-decoration: none;
      text-align: right;
    }
    .embed-link:hover { color: var(--text); }
  </style>
</Layout>
