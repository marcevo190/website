---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Motorsport — TrackMarc Motorsport Photography"
  description="Live F1 race calendar and latest motorsport news from WEC, WRC, GT and Irish motorsport."
>
  <div style="padding-top: var(--nav-height);">
    <div class="section">

      <div class="section-header">
        <p class="section-eyebrow">The Sport</p>
        <h1 class="section-title">Motorsport</h1>
        <p class="section-subtitle">
          Live F1 race calendar and the latest news across the major series — automatically updated.
        </p>
      </div>

      <!-- F1 CALENDAR -->
      <div class="feed-section">
        <div class="series-heading">
          <span class="series-dot"></span>
          <span class="series-name">Formula 1</span>
          <span class="series-badge" id="f1-badge"></span>
          <a href="https://www.formula1.com/en/racing/2026" target="_blank" rel="noopener" class="series-link">Calendar ↗</a>
        </div>
        <div class="events-grid" id="f1-races">
          <div class="event-card"><div class="skel" style="width:3.5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:72%;height:1rem;margin-bottom:0.5rem;"></div><div class="skel" style="width:50%;height:0.75rem;"></div></div>
          <div class="event-card"><div class="skel" style="width:3.5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:65%;height:1rem;margin-bottom:0.5rem;"></div><div class="skel" style="width:55%;height:0.75rem;"></div></div>
          <div class="event-card"><div class="skel" style="width:3.5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:78%;height:1rem;margin-bottom:0.5rem;"></div><div class="skel" style="width:45%;height:0.75rem;"></div></div>
        </div>
      </div>

      <!-- WEC -->
      <div class="feed-section">
        <div class="series-heading">
          <span class="series-dot"></span>
          <span class="series-name">FIA World Endurance Championship</span>
          <a href="https://www.fiawec.com/en/season/" target="_blank" rel="noopener" class="series-link">Calendar ↗</a>
        </div>
        <div class="events-grid" id="wec-news">
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:85%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:70%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:90%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:60%;height:0.7rem;"></div></div>
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:75%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:90%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:80%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:65%;height:0.7rem;"></div></div>
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:80%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:60%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:70%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:85%;height:0.7rem;"></div></div>
        </div>
      </div>

      <!-- WRC -->
      <div class="feed-section">
        <div class="series-heading">
          <span class="series-dot"></span>
          <span class="series-name">FIA World Rally Championship</span>
          <a href="https://www.wrc.com/en/calendar/" target="_blank" rel="noopener" class="series-link">Calendar ↗</a>
        </div>
        <div class="events-grid" id="wrc-news">
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:80%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:65%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:85%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:55%;height:0.7rem;"></div></div>
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:90%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:75%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:60%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:80%;height:0.7rem;"></div></div>
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:70%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:85%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:75%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:50%;height:0.7rem;"></div></div>
        </div>
      </div>

      <!-- GT WORLD CHALLENGE -->
      <div class="feed-section">
        <div class="series-heading">
          <span class="series-dot"></span>
          <span class="series-name">GT World Challenge Europe</span>
          <a href="https://www.gt-world-challenge-europe.com/calendar/" target="_blank" rel="noopener" class="series-link">Calendar ↗</a>
        </div>
        <div class="events-grid" id="gt-news">
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:78%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:60%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:88%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:65%;height:0.7rem;"></div></div>
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:85%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:70%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:55%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:75%;height:0.7rem;"></div></div>
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:65%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:80%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:70%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:90%;height:0.7rem;"></div></div>
        </div>
      </div>

      <!-- IRISH MOTORSPORT -->
      <div class="feed-section">
        <div class="series-heading">
          <span class="series-dot"></span>
          <span class="series-name">Irish Motorsport</span>
          <a href="https://motorsportireland.ie/events/" target="_blank" rel="noopener" class="series-link">Events ↗</a>
        </div>
        <div class="events-grid" id="irish-news">
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:82%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:68%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:92%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:58%;height:0.7rem;"></div></div>
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:76%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:88%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:63%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:78%;height:0.7rem;"></div></div>
          <div class="event-card"><div class="skel" style="width:5rem;height:0.6rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:72%;height:0.9rem;margin-bottom:0.4rem;"></div><div class="skel" style="width:55%;height:0.9rem;margin-bottom:0.75rem;"></div><div class="skel" style="width:82%;height:0.7rem;margin-bottom:0.3rem;"></div><div class="skel" style="width:70%;height:0.7rem;"></div></div>
        </div>
      </div>

      <!-- CTA -->
      <div class="accred-cta">
        <p class="section-eyebrow">Accreditation</p>
        <h3 class="accred-title">Seeking Media Access</h3>
        <p class="accred-desc">
          If you're a press officer or series coordinator and you'd like to discuss media credentials, get in touch.
        </p>
        <a href="/contact" class="btn btn-primary accred-btn">Contact Me &rarr;</a>
      </div>

    </div>
  </div>

  <script>
    function fmtDate(str: string) {
      const d = new Date(str);
      return isNaN(d.getTime()) ? str : d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
    }

    async function fetchFeed(url: string, attempt = 1): Promise<{ title: string; link: string; pubDate: string; description: string }[]> {
      const res = await fetch(`/api/rss?url=${encodeURIComponent(url)}`, { signal: AbortSignal.timeout(15000) });
      if (!res.ok) {
        if (attempt < 3) {
          await new Promise(r => setTimeout(r, 1500 * attempt));
          return fetchFeed(url, attempt + 1);
        }
        throw new Error(`HTTP ${res.status}`);
      }
      const text = await res.text();
      const doc = new DOMParser().parseFromString(text, 'text/xml');
      if (doc.querySelector('parsererror')) throw new Error('parse error');
      return Array.from(doc.querySelectorAll('item, entry')).slice(0, 6).map(el => {
        const get = (tag: string) => el.querySelector(tag)?.textContent?.trim() ?? '';
        const linkEl = el.querySelector('link');
        const link = linkEl?.getAttribute('href') ?? linkEl?.textContent?.trim() ?? '#';
        const desc = (get('description') || get('summary') || get('content'))
          .replace(/<[^>]+>/g, '').slice(0, 120).trim();
        return { title: get('title'), link, pubDate: get('pubDate') || get('published') || get('updated'), description: desc };
      });
    }

    function renderCards(id: string, items: { title: string; link: string; pubDate: string; description: string }[]) {
      const el = document.getElementById(id);
      if (!el) return;
      if (!items.length) {
        el.innerHTML = `<div class="event-card"><div class="event-series" style="opacity:0.4;">No recent articles found.</div></div>`;
        return;
      }
      el.innerHTML = items.map(item => `
        <a href="${item.link}" target="_blank" rel="noopener" class="event-card">
          <div class="event-series">${fmtDate(item.pubDate)}</div>
          <div class="event-name">${item.title}</div>
          ${item.description ? `<div class="event-detail" style="margin-top:0.5rem;">${item.description}…</div>` : ''}
        </a>`).join('');
    }

    function renderErr(id: string) {
      const el = document.getElementById(id);
      if (el) el.innerHTML = `<div class="event-card"><div class="event-series" style="opacity:0.4;">No recent articles found.</div></div>`;
    }

    // ── F1 ────────────────────────────────────────────────────────────────────
    (async () => {
      const year = new Date().getFullYear();
      const badge = document.getElementById('f1-badge');
      if (badge) badge.textContent = `${year}`;
      try {
        const res = await fetch(`https://api.jolpi.ca/ergast/f1/${year}/races/?format=json&limit=30`);
        const data = await res.json();
        const races = (data?.MRData?.RaceTable?.Races ?? []) as any[];
        const upcoming = races.filter(r => new Date(`${r.date}T${r.time ?? '12:00:00Z'}`) >= new Date());
        const container = document.getElementById('f1-races')!;
        if (!upcoming.length) {
          container.innerHTML = `<div class="event-card"><div class="event-series">Season complete</div><div class="event-name" style="opacity:0.5;font-size:0.9rem;">No upcoming rounds this season.</div></div>`;
          return;
        }
        container.innerHTML = upcoming.map(r => `
          <div class="event-card">
            <div class="event-series">Round ${r.round}</div>
            <div class="event-name">${r.raceName}</div>
            <div class="event-detail">${r.Circuit.circuitName}</div>
            <div class="event-detail" style="margin-top:0.15rem;">${r.Circuit.Location.locality}, ${r.Circuit.Location.country}</div>
            <div class="event-date">${fmtDate(r.date)}</div>
          </div>`).join('');
      } catch { renderErr('f1-races'); }
    })();

    // ── News feeds — sequential to avoid rate limits ──────────────────────────
    const feeds = [
      { id: 'wec-news',   url: 'https://news.google.com/rss/search?q=FIA+WEC+World+Endurance+Championship+racing&hl=en&gl=US&ceid=US:en' },
      { id: 'wrc-news',   url: 'https://news.google.com/rss/search?q=World+Rally+Championship+WRC&hl=en&gl=US&ceid=US:en' },
      { id: 'gt-news',    url: 'https://news.google.com/rss/search?q=GT+World+Challenge+Europe+SRO+Fanatec&hl=en&gl=US&ceid=US:en' },
      { id: 'irish-news', url: 'https://news.google.com/rss/search?q=Motorsport+Ireland+racing+rally&hl=en&gl=US&ceid=US:en' },
    ];

    (async () => {
      for (const { id, url } of feeds) {
        try { renderCards(id, await fetchFeed(url)); }
        catch { renderErr(id); }
      }
    })();
  </script>

  <style is:global>
    /* ── Layout ── */
    .feed-section { margin-bottom: 4.5rem; }

    /* ── Series heading ── */
    .series-heading {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--border);
    }
    .series-dot {
      display: block;
      width: 7px; height: 7px;
      background: var(--accent);
      border-radius: 50%;
      flex-shrink: 0;
    }
    .series-name {
      font-family: var(--font-heading);
      font-size: 1rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text);
    }
    .series-badge {
      font-family: var(--font-heading);
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      color: var(--text-dim);
      background: var(--surface-2);
      border: 1px solid var(--border);
      padding: 0.2rem 0.55rem;
      line-height: 1.6;
    }
    .series-link {
      margin-left: auto;
      font-family: var(--font-heading);
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      opacity: 0.65;
      transition: opacity 0.2s;
      flex-shrink: 0;
    }
    .series-link:hover { opacity: 1; }

    /* ── Skeleton shimmer ── */
    @keyframes shimmer {
      0%   { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
    .skel {
      display: block;
      background: linear-gradient(90deg, var(--surface) 25%, var(--surface-2) 50%, var(--surface) 75%);
      background-size: 400% 100%;
      animation: shimmer 1.5s ease-in-out infinite;
      border-radius: 2px;
    }

    /* .accred-cta styles now live in global.css (shared with licensing) */

    @media (max-width: 768px) {
      .feed-section { margin-bottom: 2.5rem; }
      .series-heading { flex-wrap: wrap; row-gap: 0.4rem; }
      .series-name { font-size: 0.85rem; }
      .series-link { margin-left: 0; }
    }
  </style>
</Layout>
