---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCaption } from '../data/captions';

// Auto-scan category folders — drop a photo in the folder, it appears here
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/watermarked/{formula,endurance,rally,gt,car-shows}/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

const categories = ['formula', 'endurance', 'rally', 'gt', 'car-shows'] as const;
const categoryLabels: Record<string, string> = {
  'formula': 'Formula',
  'endurance': 'Endurance',
  'rally': 'Rally',
  'gt': 'GT',
  'car-shows': 'Car Shows',
};

const photos = Object.entries(imageModules).map(([path, mod]) => {
  const parts = path.split('/');
  const filename = parts[parts.length - 1];
  // folder is the category — one level above the file, inside watermarked/
  const folder = parts[parts.length - 2] as typeof categories[number];
  // Derive a readable title from the filename (remove extension, replace - and _ with spaces)
  const autoTitle = filename
    .replace(/\.[^.]+$/, '')
    .replace(/[-_]/g, ' ')
    .replace(/\b\w/g, c => c.toUpperCase());
  const cap = getCaption(filename);
  return {
    src: mod.default,
    category: folder,
    title: cap?.title ?? autoTitle,
    caption: cap?.caption ?? '',
    filename,
  };
});

const hasPhotos = photos.length > 0;
const populatedCategories = categories.filter(cat => photos.some(p => p.category === cat));
---

<Layout
  title="Gallery — TrackMarc Motorsport Photography"
  description="Motorsport photography portfolio by Marc Ronan — Formula 1, WEC endurance racing, GT and car shows across Europe."
>
  <div style="padding-top: var(--nav-height);">
    <div class="section">
      <div class="section-header">
        <p class="section-eyebrow">Portfolio</p>
        <h1 class="section-title">Gallery</h1>
        <p class="section-subtitle">
          {hasPhotos
            ? `${photos.length} image${photos.length !== 1 ? 's' : ''} across ${categories.length} categories. Click any photo to view full size.`
            : 'Photos coming soon. Check back after the next event.'}
        </p>
        <p style="margin-top:0.5rem;font-size:0.78rem;color:var(--text-dim);">
          All images &copy; Marc Ronan. For press or editorial use see <a href="/licensing" style="color:var(--accent);">licensing</a>.
        </p>
      </div>

      {hasPhotos && (
        <div class="gallery-filters" id="filters">
          {(['all', ...populatedCategories] as const).map((cat) => (
            <button
              class:list={['filter-btn', { active: cat === 'all' }]}
              data-filter={cat}
            >
              {cat === 'all' ? 'All' : (categoryLabels[cat] ?? cat)}
            </button>
          ))}
        </div>
      )}

      {hasPhotos ? (
        <div class="gallery-masonry" id="gallery">
          {photos.map((photo) => (
            <div
              class="photo-card"
              data-category={photo.category}
              data-title={photo.title}
              data-caption={photo.caption}
            >
              <Image
                src={photo.src}
                alt={photo.title}
                widths={[400, 800, 1200]}
                sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
              />
              <div class="photo-card-overlay">
                <div class="photo-card-meta">
                  <p class="photo-card-title">{photo.title}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div style="text-align: center; padding: 6rem 0; color: var(--text-dim);">
          <div style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.3;">📷</div>
          <p style="font-family: var(--font-heading); font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase;">
            Uploading soon
          </p>
        </div>
      )}
    </div>
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close">&#x2715; Close</button>
    <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Previous">&#8592;</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Next">&#8594;</button>
    <div class="lightbox-meta">
      <div class="photo-card-title" id="lightbox-title"></div>
      <p class="lightbox-caption" id="lightbox-caption"></p>
    </div>
  </div>

  <script>
    // Filter
    const filters = document.getElementById('filters');
    const cards = document.querySelectorAll<HTMLElement>('#gallery .photo-card');

    filters?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.filter-btn') as HTMLElement | null;
      if (!btn) return;
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.category === filter;
        card.style.display = show ? '' : 'none';
      });
    });

    // Lightbox
    const lightbox = document.getElementById('lightbox');
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const lbTitle = document.getElementById('lightbox-title');
    const lbCaption = document.getElementById('lightbox-caption');
    const lbClose = document.getElementById('lightbox-close');
    const lbPrev = document.getElementById('lightbox-prev');
    const lbNext = document.getElementById('lightbox-next');

    let currentIndex = 0;

    function visibleCards() {
      return Array.from(cards).filter(c => (c as HTMLElement).style.display !== 'none');
    }

    function showCard(index: number) {
      const visible = visibleCards();
      if (!visible.length) return;
      currentIndex = (index + visible.length) % visible.length;
      const card = visible[currentIndex] as HTMLElement;
      const img = card.querySelector('img');
      if (lbImg && img) { lbImg.src = img.src; lbImg.alt = img.alt; }
      if (lbTitle) lbTitle.textContent = card.dataset.title ?? '';
      if (lbCaption) lbCaption.textContent = card.dataset.caption ?? '';
    }

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const visible = visibleCards();
        currentIndex = visible.indexOf(card as HTMLElement);
        showCard(currentIndex);
        lightbox?.classList.add('open');
      });
    });

    lbPrev?.addEventListener('click', (e) => { e.stopPropagation(); showCard(currentIndex - 1); });
    lbNext?.addEventListener('click', (e) => { e.stopPropagation(); showCard(currentIndex + 1); });

    lbClose?.addEventListener('click', () => lightbox?.classList.remove('open'));
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) lightbox.classList.remove('open');
    });
    document.addEventListener('keydown', (e) => {
      if (!lightbox?.classList.contains('open')) return;
      if (e.key === 'Escape') lightbox.classList.remove('open');
      if (e.key === 'ArrowLeft') showCard(currentIndex - 1);
      if (e.key === 'ArrowRight') showCard(currentIndex + 1);
    });
  </script>
</Layout>
