---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Auto-scan category folders — drop a photo in the folder, it appears here
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/{formula,endurance,rally,gt,car-shows}/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

const categories = ['formula', 'endurance', 'rally', 'gt', 'car-shows'] as const;
const categoryLabels: Record<string, string> = {
  'formula': 'Formula',
  'endurance': 'Endurance',
  'rally': 'Rally',
  'gt': 'GT',
  'car-shows': 'Car Shows',
};

const photos = Object.entries(imageModules).map(([path, mod]) => {
  const parts = path.split('/');
  const filename = parts[parts.length - 1];
  const folder = parts[parts.length - 2] as typeof categories[number];
  // Derive a readable title from the filename (remove extension, replace - and _ with spaces)
  const title = filename
    .replace(/\.[^.]+$/, '')
    .replace(/[-_]/g, ' ')
    .replace(/\b\w/g, c => c.toUpperCase());
  return {
    src: mod.default,
    category: folder,
    title,
    filename,
  };
});

const hasPhotos = photos.length > 0;
const populatedCategories = categories.filter(cat => photos.some(p => p.category === cat));
---

<Layout
  title="Gallery — TrackMarc Motorsport Photography"
  description="Full portfolio of motorsport photography — Formula, Endurance, Rally, GT across Europe."
>
  <div style="padding-top: var(--nav-height);">
    <div class="section">
      <div class="section-header">
        <p class="section-eyebrow">Portfolio</p>
        <h1 class="section-title">Gallery</h1>
        <p class="section-subtitle">
          {hasPhotos
            ? `${photos.length} image${photos.length !== 1 ? 's' : ''} across ${categories.length} categories. Click any photo to view full size.`
            : 'Photos coming soon. Check back after the next event.'}
        </p>
      </div>

      {hasPhotos && (
        <div class="gallery-filters" id="filters">
          {(['all', ...populatedCategories] as const).map((cat) => (
            <button
              class:list={['filter-btn', { active: cat === 'all' }]}
              data-filter={cat}
            >
              {cat === 'all' ? 'All' : (categoryLabels[cat] ?? cat)}
            </button>
          ))}
        </div>
      )}

      {hasPhotos ? (
        <div class="gallery-masonry" id="gallery">
          {photos.map((photo) => (
            <div
              class="photo-card"
              data-category={photo.category}
              data-title={photo.title}
            >
              <Image
                src={photo.src}
                alt={photo.title}
                widths={[400, 800, 1200]}
                sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
              />
            </div>
          ))}
        </div>
      ) : (
        <div style="text-align: center; padding: 6rem 0; color: var(--text-dim);">
          <div style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.3;">📷</div>
          <p style="font-family: var(--font-heading); font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase;">
            Uploading soon
          </p>
        </div>
      )}
    </div>
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close">&#x2715; Close</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    <div class="lightbox-meta">
      <div class="photo-card-title" id="lightbox-title"></div>
      <div class="photo-card-event" id="lightbox-event"></div>
    </div>
  </div>

  <script>
    // Filter
    const filters = document.getElementById('filters');
    const cards = document.querySelectorAll<HTMLElement>('#gallery .photo-card');

    filters?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.filter-btn') as HTMLElement | null;
      if (!btn) return;
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.category === filter;
        card.style.display = show ? '' : 'none';
      });
    });

    // Lightbox
    const lightbox = document.getElementById('lightbox');
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const lbTitle = document.getElementById('lightbox-title');
    const lbEvent = document.getElementById('lightbox-event');
    const lbClose = document.getElementById('lightbox-close');

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const img = card.querySelector('img');
        if (lbImg && img) { lbImg.src = img.src; lbImg.alt = img.alt; }
        lightbox?.classList.add('open');
      });
    });

    lbClose?.addEventListener('click', () => lightbox?.classList.remove('open'));
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) lightbox.classList.remove('open');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') lightbox?.classList.remove('open');
    });
  </script>
</Layout>
