---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Motorsport photography by Marc — capturing speed, power, and drama from the pit lane to the podium.',
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <nav class="nav" id="main-nav">
      <a href="/" class="nav-logo">Track<span>Marc</span></a>
      <ul class="nav-links">
        <li><a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a></li>
        <li><a href="/gallery" class:list={[{ active: currentPath.startsWith('/gallery') }]}>Gallery</a></li>
        <li><a href="/coverage" class:list={[{ active: currentPath.startsWith('/coverage') }]}>Coverage</a></li>
        <li><a href="/motorsport" class:list={[{ active: currentPath.startsWith('/motorsport') }]}>Motorsport</a></li>
        <li><a href="/about" class:list={[{ active: currentPath.startsWith('/about') }]}>About</a></li>
        <li><a href="/contact" class:list={[{ active: currentPath.startsWith('/contact') }]}>Contact</a></li>
      </ul>
      <a href="/contact" class="nav-cta">Get in Touch</a>
      <button class="nav-hamburger" id="hamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </nav>

    <div class="mobile-menu" id="mobile-menu">
      <a href="/" onclick="closeMobileMenu()">Home</a>
      <a href="/gallery" onclick="closeMobileMenu()">Gallery</a>
      <a href="/coverage" onclick="closeMobileMenu()">Coverage</a>
      <a href="/motorsport" onclick="closeMobileMenu()">Motorsport</a>
      <a href="/about" onclick="closeMobileMenu()">About</a>
      <a href="/contact" onclick="closeMobileMenu()">Contact</a>
      <a href="/contact" class="mobile-cta" onclick="closeMobileMenu()">Press Inquiry</a>
    </div>

    <div class="page-content">
      <slot />
    </div>

    <footer class="footer">
      <div class="footer-logo">Track<span>Marc</span></div>
      <p class="footer-copy">&copy; {new Date().getFullYear()} TrackMarc. All rights reserved.</p>
      <div class="footer-links">
        <a href="/gallery">Gallery</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="mailto:info@trackmarc.com">info@trackmarc.com</a>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('main-nav');
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');

      window.addEventListener('scroll', () => {
        nav?.classList.toggle('scrolled', window.scrollY > 40);
      }, { passive: true });

      hamburger?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.toggle('open');
        hamburger.classList.toggle('open', isOpen);
        document.body.style.overflow = isOpen ? 'hidden' : '';
      });

      (window as any).closeMobileMenu = () => {
        mobileMenu?.classList.remove('open');
        hamburger?.classList.remove('open');
        document.body.style.overflow = '';
      };
    </script>
  </body>
</html>
